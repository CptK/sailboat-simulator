<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
	<name>Open Water</name>
	<!--
	  The 240 x 240 m square of water is the same. Inside it sits the 50 x 50 m
	  square marked by the four buoys, at local metres (0,0)-(50,50). It is
	  nested one level deep, so map_loader classifies it as land: the planner
	  routes around it and no leg may cross it, tacking included. Without it the
	  upwind leg tacks straight through the middle of the course.

	  The nested square does not extend the bounding box, so the projection
	  origin matches OpenWater.kml and map metres still equal simulation metres.

	  The island is drawn on the buoys exactly; clearance comes from the
	  planner's `margin` parameter, which erodes the water away from every
	  shoreline and island at once.
	-->
	<Placemark>
		<name>Open Water</name>
		<Polygon>
			<outerBoundaryIs>
				<LinearRing>
					<coordinates>
						8.649741493,49.876595122,0
						8.653080507,49.876595122,0
						8.653080507,49.878752878,0
						8.649741493,49.878752878,0
						8.649741493,49.876595122,0
					</coordinates>
				</LinearRing>
			</outerBoundaryIs>
		</Polygon>
	</Placemark>
	<Placemark>
		<name>Course Area</name>
		<Polygon>
			<outerBoundaryIs>
				<LinearRing>
					<coordinates>
						8.651411000,49.877674000,0
						8.652106628,49.877674000,0
						8.652106628,49.878123532,0
						8.651411000,49.878123532,0
						8.651411000,49.877674000,0
					</coordinates>
				</LinearRing>
			</outerBoundaryIs>
		</Polygon>
	</Placemark>
</Document>
</kml>
